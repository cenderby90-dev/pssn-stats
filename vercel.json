{
  "version": 2,
  "builds": [
    { "src": "api/*.js", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/attendance", "dest": "/api/attendance.js" },
    { "src": "/api/submissions", "dest": "/api/submissions.js" },
    { "src": "/api/players", "dest": "/api/players.js" },
    { "src": "/api/awards", "dest": "/api/awards.js" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
